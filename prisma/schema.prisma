generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id            String          @id @default(cuid())
  name          String
  email         String?         @unique
  productivity  Float           @default(0.0)
  revenue       Float           @default(0.0)
  accounts      WorkerAccount[]
  content       Content[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Account {
  id        String          @id @default(cuid())
  name      String
  platform  String          // e.g., "X", "LinkedIn", "Instagram"
  handle    String?
  workers   WorkerAccount[]
  content   Content[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model WorkerAccount {
  workerId  String
  accountId String
  worker    Worker  @relation(fields: [workerId], references: [id])
  account   Account @relation(fields: [accountId], references: [id])

  @@id([workerId, accountId])
}

model Content {
  id              String   @id @default(cuid())
  topic           String
  hook            String
  body            String?
  status          String   @default("draft") // draft, scheduled, posted
  score           Int      @default(0)     // 0-100
  aiScore         Int      @default(0)
  userScore       Int      @default(0)
  views           Int      @default(0)
  likes           Int      @default(0)
  shares          Int      @default(0)
  revenue         Float    @default(0.0)
  workerId        String?
  accountId       String?
  worker          Worker?  @relation(fields: [workerId], references: [id])
  account         Account? @relation(fields: [accountId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
